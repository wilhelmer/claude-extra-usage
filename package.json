{
  "name": "claude-extra-usage",
  "displayName": "Claude Extra Usage",
  "repository": "https://github.com/wilhelmer/claude-extra-usage",
  "description": "Displays Claude extra credit usage as a percentage in the VS Code status bar.",
  "author": "Lars Wilhelmer",
  "publisher": "LWilhelmer",
  "version": "0.0.1",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeExtraUsage.refresh",
        "title": "Claude Extra Usage: Refresh Now"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
